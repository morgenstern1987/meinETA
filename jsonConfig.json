{
  "type": "panel",
  "items": {
    "ip": {
      "type": "text",
      "label": "IP-Adresse des ETAtouch",
      "placeholder": "192.168.1.100",
      "sm": 12,
      "md": 6
    },
    "port": {
      "type": "number",
      "label": "Port",
      "min": 1,
      "max": 65535,
      "sm": 12,
      "md": 3,
      "default": 8080
    },
    "pollInterval": {
      "type": "number",
      "label": "Abfrage-Intervall (Sekunden)",
      "min": 10,
      "max": 3600,
      "sm": 12,
      "md": 3,
      "default": 60
    },
    "_divider": {
      "type": "divider"
    },
    "_groupsHeader": {
      "type": "header",
      "text": "Zu überwachende Gruppen",
      "size": 5
    },
    "groupPuffer": {
      "type": "checkbox",
      "label": "PufferFlex",
      "sm": 12,
      "md": 4,
      "default": true
    },
    "groupKessel": {
      "type": "checkbox",
      "label": "Kessel",
      "sm": 12,
      "md": 4,
      "default": true
    },
    "groupHK": {
      "type": "checkbox",
      "label": "HK (Heizkreis)",
      "sm": 12,
      "md": 4,
      "default": true
    },
    "groupLager": {
      "type": "checkbox",
      "label": "Lager",
      "sm": 12,
      "md": 4,
      "default": true
    },
    "groupKamin": {
      "type": "checkbox",
      "label": "Kamin",
      "sm": 12,
      "md": 4,
      "default": true
    }
  }
}
