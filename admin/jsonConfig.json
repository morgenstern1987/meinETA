{
  "type": "panel",
  "items": {
    "host": {
      "type": "text",
      "label": "ETA IP Adresse"
    },
    "port": {
      "type": "number",
      "label": "Port",
      "default": 8080
    },
    "pollInterval": {
      "type": "number",
      "label": "Polling Intervall (ms)",
      "default": 60000
    },
    "varset": {
      "type": "text",
      "label": "ETA VarSet",
      "default": "iobroker"
    },
    "variables": {
      "type": "select",
      "label": "Zu pollende Variablen",
      "multiple": true,
      "options": [
        { "label": "Boiler Temperatur", "value": "kessel.temperatur" },
        { "label": "Boiler Leistung", "value": "kessel.leistung" },
        { "label": "Puffer oben", "value": "puffer.oben" },
        { "label": "Puffer unten", "value": "puffer.unten" },
        { "label": "Außentemperatur", "value": "aussen.temperatur" }
      ]
    }
  }
}
